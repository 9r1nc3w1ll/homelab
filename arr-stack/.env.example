# Copy to .env and edit. Do not commit .env.

# --- Host user for LinuxServer.io *arr images (match owner of mounted paths on disk) ---
PUID=1000
PGID=1000
TZ=Etc/UTC

# Root for media + downloads (path is relative to this compose file if not absolute)
DATA_ROOT=./data
# Root for app configs (path is relative to this compose file if not absolute)
CONFIG_ROOT=./config

# --- Ports (change if they clash on the host) ---
QBIT_WEBUI_PORT=8080
TORRENT_PORT=6881
PROWLARR_PORT=9696
SONARR_PORT=8989
RADARR_PORT=7878
LAZYLIBRARIAN_PORT=5299
LIDARR_PORT=8686
WHISPARR_PORT=6969
BAZARR_PORT=6767
JELLYFIN_HTTP=8096
JELLYFIN_HTTPS=8920
SEERR_PORT=5055
FLARESOLVERR_PORT=8191

SEERR_LOG_LEVEL=info
FLARESOLVERR_LOG_LEVEL=info

# --- Gluetun (VPN) — required for gluetun; see https://github.com/qdm12/gluetun-wiki
# Set provider and credentials for YOUR VPN. Examples differ by provider (OpenVPN vs Wireguard).
VPN_SERVICE_PROVIDER=
# VPN_TYPE=openvpn
# Wireguard example (Mullvad, etc.):
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=
# WIREGUARD_PUBLIC_KEY=
# OpenVPN example:
# OPENVPN_USER=
# OPENVPN_PASSWORD=

# Optional: allow local LAN to reach VPN container services (see Gluetun firewall docs if needed)
# FIREWALL_OUTBOUND_SUBNETS=192.168.0.0/16

# --- Seerr config directory must be writable by UID/GID 1000 inside the container ---
# After first run error: chown -R 1000:1000 "${CONFIG_ROOT}/seerr" (host path)

# --- Jellyfin AMD/VAAPI: compose passes /dev/dri and group_add video+render.
# On the host, install Mesa/AMD VAAPI drivers (distro-specific) and verify with: vainfo
