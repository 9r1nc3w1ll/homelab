# Copy to .env and edit. Do not commit .env.

# --- Host user for LinuxServer.io *arr images (match owner of DATA_ROOT on disk) ---
PUID=1000
PGID=1000
TZ=Etc/UTC

# Root for media + configs + downloads (path is relative to this compose file if not absolute)
DATA_ROOT=./data

# --- Ports (change if they clash on the host) ---
QBIT_WEBUI_PORT=8080
TORRENT_PORT=6881
PROWLARR_PORT=9696
SONARR_PORT=8989
RADARR_PORT=7878
BAZARR_PORT=6767
JELLYFIN_HTTP=8096
JELLYFIN_HTTPS=8920
SEERR_PORT=5055
FLARESOLVERR_PORT=8191

SEERR_LOG_LEVEL=info
FLARESOLVERR_LOG_LEVEL=info

# --- Gluetun (VPN) — required for gluetun; see https://github.com/qdm12/gluetun-wiki
# Set provider and credentials for YOUR VPN. Examples differ by provider (OpenVPN vs Wireguard).
VPN_SERVICE_PROVIDER=
# VPN_TYPE=openvpn
# Wireguard example (Mullvad, etc.):
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=
# WIREGUARD_PUBLIC_KEY=
# OpenVPN example:
# OPENVPN_USER=
# OPENVPN_PASSWORD=

# Optional: allow local LAN to reach VPN container services (see Gluetun firewall docs if needed)
# FIREWALL_OUTBOUND_SUBNETS=192.168.0.0/16

# --- Seerr config directory must be writable by UID/GID 1000 inside the container ---
# After first run error: chown -R 1000:1000 "${DATA_ROOT}/seerr" (host path)
